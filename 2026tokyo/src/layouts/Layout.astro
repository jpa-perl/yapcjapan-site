---
import "../styles/global.css";
import { siteInfo, navItems } from "../data/site";

interface Props {
  title?: string;
}

const { title = siteInfo.title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/2026tokyo/favicon.svg" />
    <link rel="icon" href="/2026tokyo/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@500;700;900&family=Solway:wght@500;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-black font-maru">

    <header class="bg-white rounded-b-[28px]">
      <div class="flex items-center justify-between px-5 py-4">
        <a href="/2026tokyo/" class="font-solway font-extrabold text-lg text-black">
          {siteInfo.title}
        </a>
        <nav>
          <ul class="flex gap-6">
            {navItems.map((item) => (
              <li>
                <a href={item.href} class="flex flex-col items-center gap-1.5 text-brown text-center">
                  <span class="font-maru font-black text-lg leading-none">{item.label}</span>
                  <span class="font-solway font-medium text-xs leading-none opacity-80">{item.labelEn}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="bg-white border-t border-dashed border-gray-500 py-8 flex flex-col items-center gap-2">
      <small class="font-solway font-medium text-xs text-navy opacity-80">&copy; Japan Perl Association</small>
    </footer>
  </body>
</html>

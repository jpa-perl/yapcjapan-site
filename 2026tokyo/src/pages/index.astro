---
import Layout from "../layouts/Layout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import SpeakerCard from "../components/SpeakerCard.astro";
import {
  siteInfo,
  announcements,
  keynoteSpeaker,
  speakers,
} from "../data/site";
---

<Layout>
  <section id="hero" class="relative bg-gray-200">
    <div id="hero-shapes" class="absolute inset-0 pointer-events-none">
      <img id="shape-gold-left-top" src="/2026tokyo/images/shape-gold-left-top.svg" alt="" class="absolute" />
      <img id="shape-white-left" src="/2026tokyo/images/shape-white-left.svg" alt="" class="absolute" />
      <img id="shape-blue-right-top" src="/2026tokyo/images/shape-blue-right-top.svg" alt="" class="absolute" />
      <img id="shape-purple-right-small" src="/2026tokyo/images/shape-purple-right-small.svg" alt="" class="absolute" />
      <img id="shape-green-center-top" src="/2026tokyo/images/shape-green-center-top.svg" alt="" class="absolute" />
      <img id="shape-blue-stroke-left" src="/2026tokyo/images/shape-blue-stroke-left.svg" alt="" class="absolute" />
      <img id="shape-gold-left-lower" src="/2026tokyo/images/shape-gold-left-lower.svg" alt="" class="absolute" />
      <img id="shape-orange-stroke-right" src="/2026tokyo/images/shape-orange-stroke-right.svg" alt="" class="absolute" />
      <img id="shape-gold-right" src="/2026tokyo/images/shape-gold-right.svg" alt="" class="absolute" />
      <img id="shape-orange-stroke-center" src="/2026tokyo/images/shape-orange-stroke-center.svg" alt="" class="absolute" />
      <img id="shape-white-left-bottom" src="/2026tokyo/images/shape-white-left-bottom.svg" alt="" class="absolute" />
      <img id="shape-green-right-bottom" src="/2026tokyo/images/shape-green-right-bottom.svg" alt="" class="absolute" />
    </div>
    <div class="relative z-10 flex flex-col items-center pt-72 pb-48 gap-20 max-w-screen-xl mx-auto px-5">
      <h1 class="sr-only">{siteInfo.title}</h1>
      <img src="/2026tokyo/images/hero-logo-group.svg" alt="YAPC::Tokyo 2026" width="468" height="483" />
      <img src="/2026tokyo/images/hero-date-card.svg" alt="2026 11.27 FRI → 11.29 SUN @東京ビッグサイト" width="464" height="150" />
    </div>
    <img src="/2026tokyo/images/hero-wave.svg" alt="" class="block w-full bg-cream" />
  </section>

  <section id="announcements">
    <div class="py-16 max-w-screen-xl mx-auto px-5 flex flex-col items-center gap-8">
      <SectionHeading title="Announcement" subtitle="おしらせ" />
      <ul class="w-full max-w-2xl">
        {announcements.map((item) => (
          <li class="border-t border-dashed border-gray-500">
            <a href={item.href} class="flex items-center gap-5 px-1 py-5">
              <time datetime={item.date} class="shrink-0 rounded-full border border-black bg-white px-4 py-0.5 font-solway font-medium text-base text-gray-700 text-center">
                {item.displayDate}
              </time>
              <span class="font-maru font-bold text-lg text-black">{item.title}</span>
            </a>
          </li>
        ))}
        <li class="border-t border-dashed border-gray-500" />
      </ul>
      <a href={siteInfo.blogUrl} class="bg-black text-white font-maru font-bold text-base rounded-full px-5 py-2.5 text-center">
        YAPC 公式ブログはこちら
      </a>
    </div>
    <img src="/2026tokyo/images/about-wave-top.svg" alt="" class="block w-full bg-cream" />
  </section>

  <section id="about" class="bg-gray-200">
    <div class="py-16 max-w-screen-xl mx-auto px-5 flex flex-col items-center gap-8">
      <SectionHeading title="About YAPC::Tokyo 2026" subtitle="YAPC::Tokyo 2026について" color="blue" />
      <p class="max-w-2xl text-base font-maru font-bold text-black text-center whitespace-pre-line">{siteInfo.description}</p>

      <div class="bg-white rounded-[20px] px-5 py-7 grid grid-cols-[theme(spacing.5)_1fr_theme(spacing.5)] gap-y-5">
        <div class="col-start-2 flex flex-col gap-3 items-start">
          <span class="rounded-full border border-black px-3 py-1 font-maru font-bold text-base">開催日時</span>
          <ul class="font-maru font-medium text-base leading-relaxed">
            {siteInfo.dates.map((d) => (
              <li>
                <time datetime={d.date}>{d.label}</time>  {d.note}
              </li>
            ))}
          </ul>
        </div>

        <hr class="col-span-full border-t border-dashed border-gray-500" />

        <div class="col-start-2 flex flex-col gap-3 items-start">
          <span class="rounded-full border border-black px-3 py-1 font-maru font-bold text-base">場所</span>
          <div class="font-maru font-medium text-base leading-relaxed">
            <p>{siteInfo.venue.name}</p>
            <p><a href={siteInfo.venue.accessUrl}>アクセス方法(東京ビッグサイト公式ページ)</a></p>
            <p><a href={siteInfo.venue.mapUrl}>Google Mapで見る</a></p>
          </div>
        </div>
      </div>
    </div>
    <img src="/2026tokyo/images/speakers-wave.svg" alt="" class="block w-full bg-gray-200" />
  </section>

  <section id="speakers">
    <div class="py-16 max-w-screen-xl mx-auto px-5 flex flex-col items-center gap-12">
      <SectionHeading title="Speakers" subtitle="スピーカー" />

      <section id="keynote" class="w-full max-w-xl">
        <SpeakerCard
          name={keynoteSpeaker.name}
          nameEn={keynoteSpeaker.nameEn}
          description={keynoteSpeaker.description}
          role={keynoteSpeaker.role}
          keynote
        />
      </section>

      <ul class="grid grid-cols-3 gap-12 w-full">
        {speakers.map((speaker) => (
          <li>
            <SpeakerCard
              name={speaker.name}
              nameEn={speaker.nameEn}
              description={speaker.description}
            />
          </li>
        ))}
      </ul>
    </div>
  </section>
</Layout>

<script>
  import { gsap } from "gsap";

  const DESIGN_WIDTH = 1280;

  // baseX: デザイン中心(640px)からの水平オフセット（図形左端基準）
  // baseY: Figmaフレーム上端からのY座標（図形上端基準）
  const shapes = [
    { id: "shape-gold-left-top",        baseX: -675, baseY: 104 },
    { id: "shape-white-left",           baseX: -498, baseY: 352 },
    { id: "shape-blue-right-top",       baseX:  319, baseY: 464 },
    { id: "shape-purple-right-small",   baseX:  197, baseY: 134 },
    { id: "shape-green-center-top",     baseX:  -86, baseY:  19 },
    { id: "shape-blue-stroke-left",     baseX: -681, baseY: 627 },
    { id: "shape-gold-left-lower",      baseX: -452, baseY: 859 },
    { id: "shape-orange-stroke-right",  baseX:  394, baseY: 185 },
    { id: "shape-gold-right",           baseX:  400, baseY: 817 },
    { id: "shape-orange-stroke-center", baseX:   93, baseY: 1077 },
    { id: "shape-white-left-bottom",    baseX: -406, baseY: 1103 },
    { id: "shape-green-right-bottom",   baseX:  322, baseY: 1037 },
  ];

  const heroSection = document.getElementById("hero");
  if (heroSection) {
    function updateShapes() {
      const vw = window.innerWidth;
      const cx = vw / 2;

      shapes.forEach(shape => {
        const el = document.getElementById(shape.id);
        if (!el) return;

        gsap.set(el, {
          left: cx + shape.baseX,
          top: shape.baseY,
        });
      });
    }

    window.addEventListener("resize", updateShapes);
    updateShapes();
  }
</script>
